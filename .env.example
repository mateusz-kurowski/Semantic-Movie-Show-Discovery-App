# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/movie_discovery_app

# ==========================================
# Common Settings
# ==========================================
DEBUG=true
PRODUCTION=false

# ==========================================
# Catalog Collector Settings
# ==========================================
CATALOG_COLLECTOR_SERVICE_ON=true
DATASET_LOAD_PERCENTAGE=100

# ==========================================
# Catalog Ingester Settings
# ==========================================
INGEST_BATCH_SIZE=8
INGEST_PERIOD_SECONDS=15
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_PARALLEL=2
VECTOR_DIMENSION=256

# ==========================================
# Qdrant Configuration
# ==========================================
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_USE_SSL=false
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=movies
QDRANT_DENSE_VECTOR_NAME=overview-dense-vector
QDRANT_API_KEY=

# ==========================================
# Embedding API (OpenAI-compatible)
# ==========================================
OPENAI_BASE_URL=http://localhost:11434/v1
OPENAI_API_KEY=ollama

# ==========================================
# Redis
# ==========================================
REDIS_URL=redis://localhost:6379

# ==========================================
# Embedding Service (for catalog-api)
# ==========================================
EMBEDDING_SERVICE_URL=http://localhost:8000/embed

# ==========================================
# OpenTelemetry / SigNoz
# ==========================================
OTEL_TRACES_EXPORTER=otlp
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=catalog-api
