# ==========================================
# Database Configuration
# ==========================================
DATABASE_URL=postgresql://postgres:password@localhost:5432/movie_discovery_app

# ==========================================
# Common Settings
# ==========================================
DEBUG=true
PRODUCTION=false

# ==========================================
# OpenTelemetry
# ==========================================
OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com

# ==========================================
# Catalog Collector Settings
# ==========================================
CATALOG_COLLECTOR_SERVICE_ON=true
DATASET_LOAD_PERCENTAGE=100

# ==========================================
# Catalog Ingester Settings
# ==========================================
INGEST_BATCH_SIZE=8
INGEST_PERIOD_SECONDS=15

# ==========================================
# Qdrant Configuration
# ==========================================
QDRANT_HOST=localhost
QDRANT_PORT=6334
QDRANT_USE_SSL=false
QDRANT_COLLECTION_NAME=movies
QDRANT_DENSE_VECTOR_NAME=overview-dense-vector
QDRANT_API_KEY=

# ==========================================
# Inference (Local TEI or Qdrant Cloud)
# ==========================================
# Use true to enable Qdrant Cloud inference instead of local TEI
USE_QDRANT_INFERENCE=false
QDRANT_INFERENCE_MODEL=intfloat/multilingual-e5-small

# Local TEI settings (used when USE_QDRANT_INFERENCE=false)
# When running with docker-compose, this uses the container name
EMBEDDING_MODEL_ENDPOINT=http://text-embeddings-inference:80/embed
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_PARALLEL=2
TEXT_EMBEDDINGS_PORT=38080
