{
	"$schema": "https://biomejs.dev/schemas/2.5.3/schema.json",
	"assist": {
		"actions": {
			"source": {
				"organizeImports": "on",
				"recommended": true,
				"useSortedKeys": "on"
			}
		},
		"enabled": true
	},
	"files": {
		"ignoreUnknown": false,
		"includes": ["**", "!!tmp", "!!catalog-api-requests"]
	},
	"formatter": {
		"enabled": true,
		"includes": ["**", "!!tmp", "!!catalog-api-requests"],
		"indentStyle": "tab"
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "double"
		}
	},
	"linter": {
		"enabled": true,
		"includes": ["**", "!!tmp", "!!catalog-api-requests"],
		"rules": {
			"preset": "recommended"
		}
	},
	"root": false,
	"vcs": {
		"clientKind": "git",
		"enabled": true,
		"root": "..",
		"useIgnoreFile": true
	}
}
